{
  "manifest_version": 3,
  "name": "YouTube Custom Player Skin",
  "description": "Applies a custom cinematic skin to the YouTube video player with centered controls and a sleek dark overlay.",
  "version": "0.0.3",
  "permissions": ["activeTab", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "css": ["content/skin.css"],
      "js": ["content/skin.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/bridge.js", "content/bridge/*", "content/skin/*", "content/pip.css"],
      "matches": ["*://www.youtube.com/*"]
    }
  ]
}
